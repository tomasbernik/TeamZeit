{
  "name": "teamzeit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "db:local:reset": "node database/scripts/apply-local-migrations.mjs reset",
    "db:migrations:apply": "node database/scripts/apply-local-migrations.mjs apply",
    "dev": "concurrently -n web,api -c magenta,cyan \"pnpm --filter @teamzeit/web dev\" \"pnpm --filter @teamzeit/api dev\"",
    "dev:web": "pnpm --filter @teamzeit/web dev",
    "dev:api": "pnpm --filter @teamzeit/api dev",
    "lint": "eslint .",
    "test:integration": "pnpm --filter @teamzeit/api test:integration",
    "test:e2e": "playwright test",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "supabase": "^2.109.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
