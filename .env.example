# Copy this file to .env for local development. Never commit real credentials.

WEB_ORIGIN=http://localhost:5173
API_PORT=3000

# Browser-safe values (Vite exposes only VITE_ variables to the browser)
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# API values. Never expose service-role credentials to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-anon-key
