# Copy this file to .env for local development. Never commit real credentials.

WEB_ORIGIN=http://localhost:5173
API_PORT=3000

# Browser-safe values (Vite exposes only VITE_ variables to the browser)
VITE_API_URL=http://localhost:3000/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_ANON_KEY=your-legacy-anon-key

# API values. Never expose secret/service-role credentials to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-server-only-secret-key
SUPABASE_ANON_KEY=your-legacy-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-legacy-server-only-service-role-key
SUPABASE_JWT_SECRET=your-local-jwt-secret-for-integration-tests
TIME_TRACKING_REPOSITORY=memory

# Local Supabase defaults after `supabase start`; keep real values only in .env.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_PUBLISHABLE_KEY=copy-from-PUBLISHABLE_KEY-in-supabase-status
# SUPABASE_SECRET_KEY=copy-from-SECRET_KEY-in-supabase-status
# SUPABASE_JWT_SECRET=copy-from-JWT_SECRET-in-supabase-status
# TIME_TRACKING_REPOSITORY=postgres
